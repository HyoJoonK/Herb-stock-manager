{
  "name": "herb-stock-manager",
  "version": "1.1.0",
  "description": "한의원 전용 약재 재고 관리 프로그램 (초고속 키보드 워크플로우)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "herb",
    "inventory",
    "sqlite"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.hyojoonk.herbstockmanager",
    "productName": "HerbStockManager",
    "icon": "src/assets/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "asar": true
  }
}
